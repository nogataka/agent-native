{
  "name": "@agent-native/code-agents-ui",
  "version": "0.1.74",
  "type": "module",
  "description": "Reusable React UI for Agent-Native Code surfaces.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BuilderIO/agent-native",
    "directory": "packages/code-agents-ui"
  },
  "bugs": {
    "url": "https://github.com/BuilderIO/agent-native/issues"
  },
  "homepage": "https://github.com/BuilderIO/agent-native#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./code-agents": {
      "types": "./dist/code-agents.d.ts",
      "import": "./dist/code-agents.js",
      "default": "./dist/code-agents.js"
    },
    "./styles.css": "./dist/styles.css",
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && cp src/styles.css dist/styles.css",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-select": "2.2.6",
    "@tabler/icons-react": "^3.44.0",
    "qrcode.react": "4.2.0",
    "sonner": "^2.0.7"
  },
  "peerDependencies": {
    "@agent-native/core": ">=0.24.0",
    "@agent-native/shared-app-config": ">=0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@agent-native/core": "workspace:*",
    "@agent-native/shared-app-config": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
